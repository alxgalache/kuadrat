# Server Configuration
PORT=3001
NODE_ENV=development

# Turso Database Configuration
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# AWS Settings
AWS_S3_BUCKET=140d-media-pro-243303976956-eu-south-2-an
AWS_S3_REGION=eu-south-2
CDN_BASE_URL=https://cdn.140d.art

# SMTP Email Configuration (example with Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=info@140d.art

# CORS Configuration
CLIENT_URL=http://localhost:3000

# Dealer Commission (percentage, by product type)
DEALER_COMMISSION_ART=15
DEALER_COMMISSION_OTHERS=10

# Taxes to apply to each product (when moving to other countries, we will use database)
TAX_VAT_ES=0.21

# Registration Request Email
REGISTRATION_EMAIL=axgalache@gmail.com

# Payment Provider: 'revolut' or 'stripe'
PAYMENT_PROVIDER=revolut

# Stripe (Payments) - required when PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Connect (Change #1: stripe-connect-accounts, Change #2: stripe-connect-manual-payouts)
# Change #2 reuses the same vars — no new env vars required. The webhook endpoint must
# be extended in the Stripe Dashboard to also deliver `transfer.created`, `transfer.reversed`
# and `transfer.failed` events on top of the account events subscribed in Change #1.
# Enable Stripe Connect features. Set to true once Connect is activated in the Stripe Dashboard.
STRIPE_CONNECT_ENABLED=false
# URL where Stripe redirects the artist when an account link expires (must be public).
STRIPE_CONNECT_REFRESH_URL=https://pre.140d.art/seller/stripe-connect/refresh
# URL where Stripe redirects the artist after completing the onboarding (must be public).
STRIPE_CONNECT_RETURN_URL=https://pre.140d.art/seller/stripe-connect/return
# Webhook signing secret for the Connect webhook endpoint (DIFFERENT from STRIPE_WEBHOOK_SECRET).
# Get it from Stripe Dashboard -> Webhooks -> <connect endpoint> -> Signing secret.
STRIPE_CONNECT_WEBHOOK_SECRET=

# Revolut Merchant (Payments) - required when PAYMENT_PROVIDER=revolut
# Mode: 'sandbox' or 'production'
REVOLUT_MODE=sandbox
# Secret API key from Revolut Business (Sandbox or Production)
REVOLUT_SECRET_KEY=your_revolut_secret_key
# Merchant Account ID (retrieve via dashboard or API)
REVOLUT_MERCHANT_ACCOUNT_ID=your_merchant_account_id
# Webhook signing secret (configure in Revolut dashboard when creating the webhook)
REVOLUT_WEBHOOK_SECRET=your_webhook_secret
# Public API URLs per mode (override if different from defaults)
REVOLUT_API_URL_SANDBOX=https://sandbox-merchant.revolut.com/api/merchant/1.0
REVOLUT_API_URL_PRODUCTION=https://merchant.revolut.com/api/merchant/1.0

# Revolut API version header value
REVOLUT_API_VERSION=2025-10-16
# Location ID (provided by user)
REVOLUT_LOCATION_ID=secret

# Public site base URL (must not be localhost for Revolut order URLs)
# For local/dev environments use your public domain too
SITE_PUBLIC_BASE_URL=https://pre.140d.art
SITE_API_BASE_URL=https://api.pre.140d.art

# Test access gate (optional)
# When WEB_APP_HIDDEN is true/1 the web app will be protected by a simple
# password gate intended for non-public test instances. The password itself
# is stored only on the API side in TEST_ACCESS_PASSWORD and verified via
# /api/test-access/verify; the client never exposes it.
WEB_APP_HIDDEN=false
TEST_ACCESS_PASSWORD=secret

# Rate Limiting
# General rate limiter (all endpoints)
GENERAL_RATE_LIMIT_WINDOW_SECONDS=30
GENERAL_RATE_LIMIT_MAX_REQUESTS=1000

# Auth rate limiter (login, register)
AUTH_RATE_LIMIT_WINDOW_SECONDS=30
AUTH_RATE_LIMIT_MAX_REQUESTS=60

# Sensitive operations rate limiter (order creation, payment operations)
SENSITIVE_RATE_LIMIT_WINDOW_SECONDS=30
SENSITIVE_RATE_LIMIT_MAX_REQUESTS=500

# Payment verification rate limiter (status checks, payment retrieval - supports polling)
PAYMENT_VERIFICATION_RATE_LIMIT_WINDOW_SECONDS=15
PAYMENT_VERIFICATION_RATE_LIMIT_MAX_REQUESTS=2000

# Livekit functionality
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Order reservation TTL (minutes)
ORDER_RESERVATION_TTL_MINUTES=30

# Sendcloud Shipping Integration
# API credentials from Sendcloud panel (Settings > API > API keys)
SENDCLOUD_API_KEY=your_sendcloud_api_key
SENDCLOUD_API_SECRET=your_sendcloud_api_secret
# Webhook signing secret (from Sendcloud Event Subscriptions)
SENDCLOUD_WEBHOOK_SECRET=
# Enable Sendcloud per product type (true/false). When false, legacy shipping is used.
SENDCLOUD_ENABLED_ART=true
SENDCLOUD_ENABLED_OTHERS=true
# Days after delivery to auto-confirm and credit seller earnings
SENDCLOUD_AUTO_CONFIRM_DAYS=14