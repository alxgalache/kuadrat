# NFC personalization environment — DO NOT commit the real .env file.
# Copy this file to `.env` in the same directory and fill with real values.
# This subproject runs OUTSIDE Docker, on the operator's machine, with USB
# access to the ACR1552U reader.

# Turso credentials — same values used by the backend, with write permissions
# over the nfc_tags table.
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here

# NTAG 424 DNA cryptographic material.
# MUST match the values configured in the backend's .env, otherwise programmed
# stickers will never verify.
# Generate the keys with: openssl rand -hex 16
NTAG424_SYSTEM_ID=313430
NTAG424_K_PICC=replace-with-32-hex-chars
NTAG424_MASTER_KEY=replace-with-32-hex-chars

# Base URL written into the NDEF of each sticker (BEFORE the chip injects the
# dynamic PICC and CMAC). In production: https://140d.art
# In staging/dev you may point to a test domain, but those stickers should NOT
# be shipped to real collectors.
GALLERY_BASE_URL=https://140d.art

# Human name of the operator running the personalization session. Stored in
# nfc_tags.personalized_by for audit purposes.
OPERATOR=your-name
