# Site url
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Google Maps API Key
# Required for address autocomplete feature in checkout
# See GOOGLE_PLACES_SETUP.md for setup instructions
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=secret

# Cart Address Functionality
# Options: "autocomplete" (Google Places autocomplete) or "manual" (manual input)
NEXT_PUBLIC_CART_ADDRESS_FUNC=manual

# Payment Provider: 'revolut' or 'stripe'
NEXT_PUBLIC_PAYMENT_PROVIDER=revolut

# Stripe (required when NEXT_PUBLIC_PAYMENT_PROVIDER=stripe)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Revolut (required when NEXT_PUBLIC_PAYMENT_PROVIDER=revolut)
NEXT_PUBLIC_REVOLUT_LOCALE=es

# Revolut Web SDK mode: 'sandbox' or 'production'
NEXT_PUBLIC_REVOLUT_MODE=sandbox

# Optional: Public API key (used by upsell or certain SDK features)
NEXT_PUBLIC_REVOLUT_PUBLIC_KEY=secret

# Payment timeout in milliseconds (default: 30000 = 30 seconds)
# If payment processing takes longer than this, the user will see an error and be returned to cart
NEXT_PUBLIC_PAYMENT_TIMEOUT_MS=30000

WEB_APP_HIDDEN=true

# App Publication Control
# When set to 'false', shows a "coming soon" page at root and redirects all other routes
# When set to 'true', shows the full application with all features
# Set to 'true' or '1' to publish, any other value keeps it unpublished
PUBLISHED_VISIBLE=false

NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Dealer commission percentage displayed to sellers (default: 15)
NEXT_PUBLIC_DEALER_COMMISSION=15