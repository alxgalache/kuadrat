# Site url
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Internal API URL used by Server Components to reach the backend without
# going through nginx. In Docker (see docker-compose.prod.yml) the backend
# service is named `api` and listens on port 3001, so this resolves through
# the Docker network. Leave unset for local dev outside Docker (the page
# falls back to NEXT_PUBLIC_API_URL).
INTERNAL_API_URL=http://api:3001/api

# Google Maps API Key
# Required for address autocomplete feature in checkout
# See GOOGLE_PLACES_SETUP.md for setup instructions
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=secret

# Cart Address Functionality
# Options: "autocomplete" (Google Places autocomplete) or "manual" (manual input)
NEXT_PUBLIC_CART_ADDRESS_FUNC=manual

# Payment Provider: 'revolut' or 'stripe'
NEXT_PUBLIC_PAYMENT_PROVIDER=revolut

# Stripe (required when NEXT_PUBLIC_PAYMENT_PROVIDER=stripe)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Revolut (required when NEXT_PUBLIC_PAYMENT_PROVIDER=revolut)
NEXT_PUBLIC_REVOLUT_LOCALE=es

# Revolut Web SDK mode: 'sandbox' or 'production'
NEXT_PUBLIC_REVOLUT_MODE=sandbox

# Optional: Public API key (used by upsell or certain SDK features)
NEXT_PUBLIC_REVOLUT_PUBLIC_KEY=secret

# Payment timeout in milliseconds (default: 30000 = 30 seconds)
# If payment processing takes longer than this, the user will see an error and be returned to cart
NEXT_PUBLIC_PAYMENT_TIMEOUT_MS=30000

WEB_APP_HIDDEN=true

# App Publication Control
# When set to 'false', shows a "coming soon" page at root and redirects all other routes
# When set to 'true', shows the full application with all features
# Set to 'true' or '1' to publish, any other value keeps it unpublished
PUBLISHED_VISIBLE=false

NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Dealer commission percentages displayed to sellers, by product type (default: 15)
NEXT_PUBLIC_DEALER_COMMISSION_ART=25
NEXT_PUBLIC_DEALER_COMMISSION_OTHERS=10

# VAT rates (percentage) by product type
NEXT_PUBLIC_TAX_VAT_ES=21
NEXT_PUBLIC_TAX_VAT_ART_ES=10

# Sendcloud shipping integration
# Set to 'true' to enable Sendcloud for art and/or others product types
NEXT_PUBLIC_SENDCLOUD_ENABLED_ART=true
NEXT_PUBLIC_SENDCLOUD_ENABLED_OTHERS=true

NEXT_PUBLIC_CDN_URL=https://cdn.140d.art

# Cloudflare Turnstile (captcha) for the public art-product inquiry form.
# Site key from the Cloudflare dashboard. If empty, the "haz click aquí" link
# on the art product detail page is hidden.
# The matching secret key lives in api/.env as TURNSTILE_SECRET.
# Test site key ("always passes") for development / CI: 1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA